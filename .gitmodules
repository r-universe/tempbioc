[submodule ".registry"]
	path = .registry
	url = https://github.com/tempbioc/tempbioc.r-universe.dev
	branch = HEAD
[submodule "Biobase"]
	path = Biobase
	url = https://github.com/bioc/Biobase
[submodule "BiocGenerics"]
	path = BiocGenerics
	url = https://github.com/bioc/BiocGenerics
[submodule "DirichletMultinomial"]
	path = DirichletMultinomial
	url = https://github.com/bioc/DirichletMultinomial
[submodule "LoriPkgTest2"]
	path = LoriPkgTest2
	url = https://github.com/lshep/LoriPkgTest2
[submodule "OHCA"]
	path = OHCA
	url = https://github.com/bioc/OHCA
[submodule "Rhtslib"]
	path = Rhtslib
	url = https://github.com/bioc/Rhtslib
[submodule "ontoProc"]
	path = ontoProc
	url = https://github.com/bioc/ontoProc
